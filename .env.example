# Copy this file to .env.local for local development, or set the same
# names/values in your hosting platform's environment variable dashboard
# (e.g. Vercel Project Settings > Environment Variables) for production.
# Never commit real values — this file must only ever hold placeholders.

# Shared secret gating access to /wallboard and /api/wallboard. Leave unset
# and the API is open to anyone; set this before publishing anything public.
# Generate one with: openssl rand -hex 32
WALLBOARD_ACCESS_TOKEN=change-me

# Comma-separated list of origins allowed to call /api/wallboard cross-origin
# (e.g. the domain hosting a standalone index.html on separate static
# hosting). Leave unset for same-origin-only (no CORS headers added).
WALLBOARD_ALLOWED_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Google Analytics (GA4) Realtime + Reporting Data API
GA_PROPERTY_ID=123456789
GOOGLE_APPLICATION_CREDENTIALS=/secure/path/service-account.json
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"example","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"service-account@example.iam.gserviceaccount.com"}
GA_CLIENT_EMAIL=service-account@example.iam.gserviceaccount.com
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Existing embedded database dashboard (e.g. Site24x7 public share URL)
DATABASE_DASHBOARD_URL=https://dashboard.example.com/embed/token
DATABASE_REFRESH_SECONDS=60
DATABASE_FRAME_VIEWPORT_WIDTH=1024
DATABASE_FRAME_VIEWPORT_HEIGHT=640
DATABASE_FRAME_CROP_BOTTOM=96
DATABASE_FRAME_DARK_MODE=true
DATABASE_MONITORS_STATUS_URL=https://status.example.com/monitors.json

# Passive by default; only send synthetic HEAD requests if explicitly enabled
WEBSITE_HEALTHCHECK_ENABLED=false
WEBSITE_HEALTHCHECK_URL=https://www.example.org
WEBSITE_HOSTNAME=www.example.org

# Traffic anomaly thresholds
TRAFFIC_NO_USERS_CRITICAL=false
TRAFFIC_SPIKE_THRESHOLD=350
TRAFFIC_DROP_THRESHOLD=80

# Audible alert behavior
ALERT_AUDIO_ENABLED=true
ALERT_AUDIO_COOLDOWN_SECONDS=180

# YouTube live detection (no API key required)
YOUTUBE_LIVE_CHANNEL_HANDLE=@BiltmoreChurch
YOUTUBE_FALLBACK_CHANNEL_HANDLE=@livenowfox

# DriveNC developer API. Used server-side only to discover the public HLS
# stream URLs for the configured NCDOT cameras; never expose this key to JS.
DRIVENC_API_KEY=drivenc_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Apify (Instagram + Facebook latest post scraping) — real billed compute
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APIFY_INSTAGRAM_PROFILE_URL=https://www.instagram.com/biltmorechurch/
APIFY_FACEBOOK_PAGE_URL=https://www.facebook.com/mybiltmorechurch/
